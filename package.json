{
  "name": "vesper",
  "private": true,
  "version": "0.2.3",
  "description": "A local-first multi-agent workspace for parallel sessions, tools, memory, and workflows.",
  "author": {
    "name": "ling-kong-ran",
    "email": "65328093+ling-kong-ran@users.noreply.github.com",
    "url": "https://github.com/ling-kong-ran"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node server/index.mjs",
    "build": "vite build",
    "icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "npm run icons && npm run build && electron .",
    "desktop:pack": "npm run icons && npm run build && electron-builder --publish never",
    "release": "node scripts/release.mjs",
    "lint": "oxlint",
    "test": "node --test server/tests/*.test.mjs",
    "preview": "node server/index.mjs --production",
    "start": "node server/index.mjs --production"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@larksuiteoapi/node-sdk": "^1.71.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.3",
    "dockview-react": "^7.0.4",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "officeparser": "^7.3.0",
    "openai": "^6.26.0",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "tailwindcss": "^4.3.3",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "sharp": "^0.35.3",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.lingkongran.vesper",
    "productName": "Vesper",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "build/icons/**/*",
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "package.json",
      "!server/tests/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vesper"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ling-kong-ran",
        "repo": "vesper",
        "releaseType": "release"
      }
    ]
  }
}
